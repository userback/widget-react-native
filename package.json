    "react-native-webview": ">=11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-view-shot": "^3.8.0",
    "react-native-webview": "13.12.5",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@4.13.0",
  "dependencies": {
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.76.9"
  }
