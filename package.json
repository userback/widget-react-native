{
  "name": "@userback/react-native-sdk",
  "version": "1.0.1",
  "description": "Userback feedback widget SDK for React Native",
  "license": "MIT",
  "keywords": [
    "userback",
    "feedback",
    "react-native",
    "widget",
    "sdk"
  ],
  "repository": {
